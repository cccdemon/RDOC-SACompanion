{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RDOC SACompanion",
  "version": "0.1.0",
  "identifier": "org.raumdock.sacompanion",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RDOC SACompanion",
        "width": 920,
        "height": 700,
        "minWidth": 720,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico", "icons/icon.png"]
  }
}
